{
  "$schema": "https://niceneasy.dev/schemas/brand-tokens.schema.json",
  "meta": {
    "name": "FSI Agent Squad — Swisscom Brand Tokens",
    "version": "0.2.0",
    "description": "Swisscom-aligned brand tokens for the FSI Agent Squad operational dashboard."
  },
  "color": {
    "ink": {
      "950": { "value": "#0A1524", "usage": "Dark product backgrounds — Swisscom deep navy" },
      "900": { "value": "#12223A", "usage": "Dark elevated surfaces" },
      "800": { "value": "#1C3250", "usage": "Dark borders and secondary panels" },
      "700": { "value": "#2B4A6E", "usage": "Muted dark text and structure" }
    },
    "paper": {
      "50": { "value": "#F4F7FA", "usage": "Light background" },
      "100": { "value": "#E8EEF5", "usage": "Soft sections and dividers" },
      "200": { "value": "#D0DCE8", "usage": "Warm borders and inset panels" }
    },
    "sc-blue": {
      "700": { "value": "#003A70", "usage": "Dark Swisscom blue — strong accent" },
      "500": { "value": "#005AA9", "usage": "Primary Swisscom blue accent" },
      "300": { "value": "#4A90D9", "usage": "Subtle blue highlights" },
      "100": { "value": "#8DB8E8", "usage": "Very light blue tint" }
    },
    "amber": {
      "500": { "value": "#C9972B", "usage": "Strong evidence and audit accent" },
      "400": { "value": "#D9A83A", "usage": "Evidence, audit, metadata" },
      "200": { "value": "#E8C97A", "usage": "Soft evidence tint" }
    },
    "red": {
      "600": { "value": "#B33838", "usage": "Strong risk and denial states" },
      "400": { "value": "#D94A4A", "usage": "Risk, blocked, urgent attention" },
      "200": { "value": "#E88A8A", "usage": "Soft risk tint" }
    },
    "signal": {
      "ok": { "value": "#3D9E5B", "usage": "Healthy status — green" },
      "warn": { "value": "#D9A83A", "usage": "Warning and waiting status — amber" },
      "risk": { "value": "#D94A4A", "usage": "Risk and blocked status — red" },
      "info": { "value": "#5B9BD5", "usage": "Neutral information status — blue" }
    }
  },
  "semantic": {
    "bgDark": { "value": "{color.ink.950}" },
    "surfaceDark": { "value": "{color.ink.900}" },
    "borderDark": { "value": "{color.ink.800}" },
    "bgLight": { "value": "{color.paper.50}" },
    "surfaceLight": { "value": "{color.paper.100}" },
    "borderLight": { "value": "{color.paper.200}" },
    "accentPrimary": { "value": "{color.sc-blue.500}" },
    "accentSubtle": { "value": "{color.sc-blue.300}" },
    "accentEvidence": { "value": "{color.amber.400}" },
    "accentRisk": { "value": "{color.red.400}" }
  },
  "typography": {
    "sans": { "value": "\"Inter\", \"Geist\", \"Avenir Next\", sans-serif" },
    "mono": { "value": "\"JetBrains Mono\", monospace" }
  },
  "radius": {
    "sm": { "value": "6px" },
    "md": { "value": "12px" },
    "lg": { "value": "20px" },
    "xl": { "value": "28px" }
  },
  "space": {
    "1": { "value": "4px" },
    "2": { "value": "8px" },
    "3": { "value": "12px" },
    "4": { "value": "16px" },
    "6": { "value": "24px" },
    "8": { "value": "32px" },
    "12": { "value": "48px" },
    "16": { "value": "64px" },
    "24": { "value": "96px" }
  },
  "shadow": {
    "cockpit": { "value": "0 24px 80px rgba(10, 21, 36, 0.42)" },
    "paper": { "value": "0 18px 60px rgba(43, 74, 110, 0.18)" },
    "focus": { "value": "0 0 0 3px rgba(0, 90, 169, 0.34)" }
  },
  "motion": {
    "fast": { "value": "140ms" },
    "base": { "value": "220ms" },
    "slow": { "value": "420ms" },
    "ease": { "value": "cubic-bezier(0.2, 0.8, 0.2, 1)" }
  }
}
